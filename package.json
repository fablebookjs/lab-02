{
  "name": "@fablebook/lab-02",
  "version": "2.1.0-alpha.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "npm run clean && npm run compile && npm test && npm run smoke:packed",
    "clean": "tsc -b --clean",
    "compile": "tsc -b",
    "list-packages": "node scripts/list-public-packages.mjs",
    "set-version": "node scripts/set-version.mjs",
    "smoke:packed": "node scripts/consumer-smoke.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "devDependencies": {
    "mustache": "^4.2.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
